<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- 顶部导航栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <!-- 返回按钮 -->
        <ImageView
            android:id="@+id/backButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            android:tint="@color/icon_normal" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="编辑帖子"
            android:textColor="@color/text_dark"
            android:textSize="17sp"
            android:textStyle="bold" />

        <!-- 删除按钮 -->
        <TextView
            android:id="@+id/deleteButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_button_danger"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="删除"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <!-- 保存按钮 -->
        <TextView
            android:id="@+id/saveButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/bg_publish_button"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="保存"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 加载进度 -->
    <ProgressBar
        android:id="@+id/loadingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="100dp"
        android:visibility="gone" />

    <!-- 加载提示 -->
    <TextView
        android:id="@+id/loadingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"
        android:text="加载中..."
        android:textColor="@color/text_hint_light"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- 内容区 -->
    <ScrollView
        android:id="@+id/contentScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- 标题输入区 -->
            <EditText
                android:id="@+id/titleInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_underline"
                android:gravity="center_vertical"
                android:hint="标题（选填）"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_hint_light"
                android:textSize="17sp" />

            <!-- 正文编辑区 -->
            <EditText
                android:id="@+id/contentInput"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@color/bg_page"
                android:gravity="start|top"
                android:hint="编辑帖子内容..."
                android:inputType="textMultiLine"
                android:minHeight="300dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_hint_light"
                android:textSize="15sp" />

            <!-- 已有图片预览区域 -->
            <LinearLayout
                android:id="@+id/existingImageContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已有图片"
                    android:textColor="@color/text_hint_light"
                    android:textSize="12sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/existingImageList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

            </LinearLayout>

            <!-- 新添加图片预览区域 -->
            <LinearLayout
                android:id="@+id/newImageContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="新添加图片"
                    android:textColor="@color/text_hint_light"
                    android:textSize="12sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/newImageList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

            </LinearLayout>

            <!-- 新添加附件预览区域 -->
            <LinearLayout
                android:id="@+id/newAttachContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="新添加附件"
                    android:textColor="@color/text_hint_light"
                    android:textSize="12sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/newAttachList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- 功能面板容器 -->
    <LinearLayout
        android:id="@+id/panelContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_page"
        android:visibility="gone">

        <!-- 表情面板 -->
        <include
            android:id="@+id/smileyPanel"
            layout="@layout/bottom_sheet_smiley"
            android:visibility="gone" />

        <!-- 插入面板 -->
        <include
            android:id="@+id/insertPanel"
            layout="@layout/panel_insert"
            android:visibility="gone" />

    </LinearLayout>

    <!-- 底部工具栏 -->
    <LinearLayout
        android:id="@+id/bottomToolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/surface"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- 表情 -->
                <ImageView
                    android:id="@+id/emojiButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:src="@drawable/ic_emoji"
                    android:tint="@color/icon_normal" />

                <!-- 图片 -->
                <ImageView
                    android:id="@+id/imageButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:src="@drawable/ic_image"
                    android:tint="@color/icon_normal" />

                <!-- 附件 -->
                <ImageView
                    android:id="@+id/attachButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:src="@drawable/ic_attach_file"
                    android:tint="@color/icon_normal" />

                <!-- @提及 -->
                <ImageView
                    android:id="@+id/mentionButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:src="@drawable/ic_mention"
                    android:tint="@color/icon_normal" />

                <!-- 插入 -->
                <ImageView
                    android:id="@+id/insertButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:src="@drawable/ic_insert_link"
                    android:tint="@color/icon_normal" />

            </LinearLayout>

        </HorizontalScrollView>

        <!-- 字数统计 -->
        <TextView
            android:id="@+id/charCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/10000"
            android:textColor="@color/text_hint_light"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
