<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface"
    android:fitsSystemWindows="true">

    <!-- 顶部导航 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="@null"
            android:src="@drawable/ic_back"
            android:tint="@color/text_primary"
            android:contentDescription="返回" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="登录"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="40dp">

            <!-- Tab切换 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="40dp">

                <TextView
                    android:id="@+id/tabPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="账号登录"
                    android:textColor="@color/primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:padding="8dp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="14dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@color/divider" />

                <TextView
                    android:id="@+id/tabCookie"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cookie导入"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:padding="8dp" />

            </LinearLayout>

            <!-- 账号密码登录区域 -->
            <LinearLayout
                android:id="@+id/passwordLoginLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 用户名输入框 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_user"
                            android:tint="@color/text_tertiary" />

                        <EditText
                            android:id="@+id/usernameInput"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:background="@null"
                            android:hint="用户名/QQ邮箱"
                            android:textColorHint="@color/text_tertiary"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:maxLines="1"
                            android:inputType="text" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider" />

                </LinearLayout>

                <!-- 密码输入框 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_lock"
                            android:tint="@color/text_tertiary" />

                        <EditText
                            android:id="@+id/passwordInput"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:background="@null"
                            android:hint="输入密码"
                            android:textColorHint="@color/text_tertiary"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:maxLines="1"
                            android:inputType="textPassword" />

                        <ImageButton
                            android:id="@+id/togglePassword"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@null"
                            android:src="@drawable/ic_eye_off"
                            android:tint="@color/text_tertiary"
                            android:contentDescription="显示密码" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider" />

                </LinearLayout>

                <!-- 密码提示 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="密码由6-16位数字及字母组成"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp" />

                <!-- 登录按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/loginButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="40dp"
                    android:text="立即登录"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:cornerRadius="24dp"
                    app:backgroundTint="#4FC3F7" />

                <!-- 进度条 -->
                <ProgressBar
                    android:id="@+id/loginProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Cookie导入区域 -->
            <LinearLayout
                android:id="@+id/cookieLoginLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Cookie输入框 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical|top"
                        android:paddingTop="12dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_cookie"
                            android:tint="@color/text_tertiary"
                            android:layout_marginTop="4dp" />

                        <EditText
                            android:id="@+id/cookieInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:minHeight="100dp"
                            android:background="@null"
                            android:hint="粘贴Cookie"
                            android:textColorHint="@color/text_tertiary"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:gravity="top"
                            android:inputType="textMultiLine"
                            android:maxLines="6" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider" />

                </LinearLayout>

                <!-- Cookie提示 -->
                <TextView
                    android:id="@+id/helpText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="4dp"
                    android:text="从浏览器抓包获取Cookie后粘贴\n格式：cQWy_2132_auth=xxx; cQWy_2132_saltkey=xxx"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp" />

                <!-- 导入按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/importCookieButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="40dp"
                    android:text="导入登录"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:cornerRadius="24dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#4FC3F7"
                    android:textColor="#4FC3F7" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>