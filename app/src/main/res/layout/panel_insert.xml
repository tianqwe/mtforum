<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_panel_card"
    android:padding="16dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:layout_width="3dp"
            android:layout_height="16dp"
            android:background="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="插入内容"
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 插入类型选择 - Tab布局 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_tab_container"
        android:orientation="vertical"
        android:padding="4dp">

        <!-- 第一行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/insertUrlTab"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="链接"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/bg_tab_selected" />

            <TextView
                android:id="@+id/insertImgTab"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="图片"
                android:textColor="@color/text_gray"
                android:textSize="13sp"
                android:background="@drawable/bg_tab_unselected" />

            <TextView
                android:id="@+id/insertAudioTab"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="音乐"
                android:textColor="@color/text_gray"
                android:textSize="13sp"
                android:background="@drawable/bg_tab_unselected" />

            <TextView
                android:id="@+id/insertVideoTab"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="视频"
                android:textColor="@color/text_gray"
                android:textSize="13sp"
                android:background="@drawable/bg_tab_unselected" />

        </LinearLayout>

        <!-- 第二行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/insertFlashTab"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Flash"
                android:textColor="@color/text_gray"
                android:textSize="13sp"
                android:background="@drawable/bg_tab_unselected" />

            <TextView
                android:id="@+id/insertQuoteTab"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="引用"
                android:textColor="@color/text_gray"
                android:textSize="13sp"
                android:background="@drawable/bg_tab_unselected" />

            <TextView
                android:id="@+id/insertCodeTab"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="代码"
                android:textColor="@color/text_gray"
                android:textSize="13sp"
                android:background="@drawable/bg_tab_unselected" />

            <TextView
                android:id="@+id/insertFreeTab"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="免费"
                android:textColor="@color/text_gray"
                android:textSize="13sp"
                android:background="@drawable/bg_tab_unselected" />

        </LinearLayout>

        <!-- 第三行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/insertHideTab"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="隐藏"
                android:textColor="@color/text_gray"
                android:textSize="13sp"
                android:background="@drawable/bg_tab_unselected" />

            <View
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="3" />

        </LinearLayout>

    </LinearLayout>

    <!-- 链接插入 -->
    <LinearLayout
        android:id="@+id/urlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <EditText
            android:id="@+id/urlInput"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_input_field"
            android:hint="请输入链接网址"
            android:inputType="textUri"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_disabled"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/urlTextInput"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:hint="链接文字（可选）"
            android:inputType="text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_disabled"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/insertUrlButton"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_publish_button"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="插入链接"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 图片插入 -->
    <LinearLayout
        android:id="@+id/imgPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="gone">

        <EditText
            android:id="@+id/imgUrlInput"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_input_field"
            android:hint="请输入网络图片网址"
            android:inputType="textUri"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_disabled"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/insertImgButton"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_publish_button"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="插入图片"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 音乐插入 -->
    <LinearLayout
        android:id="@+id/audioPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/audioUrlInput"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_input_field"
            android:hint="请输入音乐文件网址"
            android:inputType="textUri"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_disabled"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="支持 wma mp3 ra rm 等音乐格式"
            android:textColor="@color/text_disabled"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/insertAudioButton"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_publish_button"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="插入音乐"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 视频插入 -->
    <LinearLayout
        android:id="@+id/videoPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/videoUrlInput"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_input_field"
            android:hint="请输入视频网址（支持优酷、土豆等）"
            android:inputType="textUri"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_disabled"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="支持优酷、土豆、56、酷6等视频站"
            android:textColor="@color/text_disabled"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/insertVideoButton"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_publish_button"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="插入视频"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Flash插入 -->
    <LinearLayout
        android:id="@+id/flashPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/flashUrlInput"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_input_field"
            android:hint="请输入FLASH文件网址"
            android:inputType="textUri"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_disabled"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="支持 swf flv 等 Flash 网址"
            android:textColor="@color/text_disabled"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/insertFlashButton"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_publish_button"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="插入Flash"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 引用插入 -->
    <LinearLayout
        android:id="@+id/quotePanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/quoteInput"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/bg_input_field"
            android:gravity="start|top"
            android:hint="请输入需要引用的内容"
            android:inputType="textMultiLine"
            android:padding="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_disabled"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/insertQuoteButton"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_publish_button"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="插入引用"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 代码插入 -->
    <LinearLayout
        android:id="@+id/codePanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/codeInput"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/bg_input_field"
            android:gravity="start|top"
            android:hint="请输入代码内容"
            android:inputType="textMultiLine"
            android:padding="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_disabled"
            android:textSize="13sp"
            android:typeface="monospace" />

        <TextView
            android:id="@+id/insertCodeButton"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_publish_button"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="插入代码"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 免费信息插入 -->
    <LinearLayout
        android:id="@+id/freePanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/freeInput"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/bg_input_field"
            android:gravity="start|top"
            android:hint="如果您设置了帖子收费，请输入购买前可免费浏览的内容"
            android:inputType="textMultiLine"
            android:padding="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_disabled"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="免费信息用于收费帖子，购买前可见"
            android:textColor="@color/text_disabled"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/insertFreeButton"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_publish_button"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="插入免费信息"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 隐藏内容插入 -->
    <LinearLayout
        android:id="@+id/hidePanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/hideInput"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@drawable/bg_input_field"
            android:gravity="start|top"
            android:hint="请输入隐藏内容"
            android:inputType="textMultiLine"
            android:padding="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_disabled"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/hideCreditInput"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_field"
                android:hint="积分大于"
                android:inputType="number"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_disabled"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="可见，隐藏天数"
                android:textColor="@color/text_gray"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/hideDaysInput"
                android:layout_width="80dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_input_field"
                android:hint="不限"
                android:inputType="number"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_disabled"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:gravity="center"
                android:paddingStart="6dp"
                android:text="天"
                android:textColor="@color/text_gray"
                android:textSize="13sp" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="不设置积分和天数，默认为回复可见"
            android:textColor="@color/text_disabled"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/insertHideButton"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_publish_button"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="插入隐藏内容"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
