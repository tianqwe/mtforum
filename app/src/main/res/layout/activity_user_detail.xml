<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="false">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:fitsSystemWindows="false"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fitsSystemWindows="false"
            app:contentScrim="@color/surface"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:scrimAnimationDuration="200"
            app:titleEnabled="false">

            <!-- 背景头图区域 -->
            <FrameLayout
                android:id="@+id/coverImageContainer"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:fitsSystemWindows="false"
                app:layout_collapseMode="parallax">

                <!-- 背景头图 -->
                <ImageView
                    android:id="@+id/coverImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bg_profile_cover" />

            </FrameLayout>

            <!-- 大头像和操作按钮区域 - 折叠时隐藏 -->
            <RelativeLayout
                android:id="@+id/avatarAndButtonsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="200dp"
                android:elevation="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                app:layout_collapseMode="parallax">

                <!-- 大头像容器 -->
                <FrameLayout
                    android:id="@+id/avatarContainer"
                    android:layout_width="86dp"
                    android:layout_height="86dp"
                    android:layout_alignParentStart="true"
                    android:elevation="4dp">

                    <!-- 头像 -->
                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/userAvatar"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_user"
                        android:transitionName="avatar_transition"
                        app:civ_border_color="@color/white"
                        app:civ_border_width="4dp" />

                    <!-- Hi标签 -->
                    <TextView
                        android:id="@+id/hiTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|center_horizontal"
                        android:layout_marginTop="2dp"
                        android:background="@drawable/bg_hi_tag"
                        android:paddingStart="6dp"
                        android:paddingTop="2dp"
                        android:paddingEnd="6dp"
                        android:paddingBottom="2dp"
                        android:text="Hi"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <!-- I LOVE YOU 横幅 -->
                    <TextView
                        android:id="@+id/loveTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="2dp"
                        android:background="@drawable/bg_love_tag"
                        android:paddingStart="4dp"
                        android:paddingTop="1dp"
                        android:paddingEnd="4dp"
                        android:paddingBottom="1dp"
                        android:text="I LOVE YOU"
                        android:textColor="@color/colorPrimary"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                </FrameLayout>

                <!-- 关注和私信按钮 - 位于大头像右侧 -->
                <LinearLayout
                    android:id="@+id/buttonsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- 关注按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFollow"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="关注"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:visibility="gone"
                        app:backgroundTint="@color/highlight_orange"
                        app:cornerRadius="18dp"
                        tools:visibility="visible" />

                    <!-- 私信按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMessage"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="私信"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:visibility="gone"
                        app:backgroundTint="@color/colorPrimary"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_message_white"
                        app:iconPadding="4dp"
                        app:iconSize="16dp"
                        tools:visibility="visible" />

                </LinearLayout>

            </RelativeLayout>

            <!-- 用户信息卡片 - 折叠时隐藏 -->
            <LinearLayout
                android:id="@+id/userInfoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="240dp"
                android:background="@drawable/bg_profile_content_rounded"
                android:orientation="vertical"
                app:layout_collapseMode="parallax">

                <!-- 头像占位区域 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="50dp" />

                <!-- 用户身份与个性展示区 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <!-- 昵称与标签栏 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- 用户昵称 -->
                        <TextView
                            android:id="@+id/userName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/highlight_orange"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            tools:text="用户名" />

                        <!-- 等级标签 -->
                        <TextView
                            android:id="@+id/userLevel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_level_tag"
                            android:paddingStart="8dp"
                            android:paddingTop="3dp"
                            android:paddingEnd="8dp"
                            android:paddingBottom="3dp"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            tools:text="Lv.4" />

                        <!-- 用户组标签 -->
                        <TextView
                            android:id="@+id/userGroup"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_tag_senior"
                            android:paddingStart="8dp"
                            android:paddingTop="3dp"
                            android:paddingEnd="8dp"
                            android:paddingBottom="3dp"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            tools:text="高中生" />

                    </LinearLayout>

                    <!-- UID -->
                    <TextView
                        android:id="@+id/userUid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        tools:text="UID: 1398" />

                    <!-- 个性签名 -->
                    <TextView
                        android:id="@+id/signature"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textColor="@color/text_tertiary"
                        android:textSize="14sp"
                        android:visibility="gone"
                        tools:text="&quot;我可以陪你远方 别浪费我恨过你一场&quot;"
                        tools:visibility="visible" />

                </LinearLayout>

                <!-- 核心数据概览栏 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <!-- 帖子 -->
                    <LinearLayout
                        android:id="@+id/threadLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/threadCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/stats_number"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            tools:text="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="帖子"
                            android:textColor="@color/stats_label"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- 关注 -->
                    <LinearLayout
                        android:id="@+id/followingLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/followingCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/stats_number"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            tools:text="0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="关注"
                            android:textColor="@color/stats_label"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- 粉丝 -->
                    <LinearLayout
                        android:id="@+id/followersLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/followersCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/stats_number"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            tools:text="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="粉丝"
                            android:textColor="@color/stats_label"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- 积分 -->
                    <LinearLayout
                        android:id="@+id/creditsLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/creditsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/stats_number"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            tools:text="1160" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="积分"
                            android:textColor="@color/stats_label"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 分割线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="44dp"
                    android:background="@color/divider_background" />

            </LinearLayout>

                        <!-- 固定 Toolbar - 使用 pin 模式固定 -->
                        <androidx.appcompat.widget.Toolbar
                            android:id="@+id/toolbar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="?attr/actionBarSize"
                            app:contentInsetStart="0dp"
                            app:layout_collapseMode="pin">
            
                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">
            
                                    <LinearLayout
                                        android:id="@+id/toolbarContent"
                                        android:layout_width="match_parent"
                                        android:layout_height="?attr/actionBarSize"
                                        android:gravity="center_vertical"
                                        android:orientation="horizontal"
                                        android:paddingStart="4dp"
                                        android:paddingEnd="16dp">
            
                                        <!-- 返回按钮 -->
                                        <ImageButton
                                            android:id="@+id/btnBack"
                                            android:layout_width="44dp"
                                            android:layout_height="44dp"
                                            android:background="?attr/selectableItemBackgroundBorderless"
                                            android:src="@drawable/ic_back_white"
                                            android:tint="@color/white" />
            
                                        <!-- 折叠后显示的小头像 -->
                                        <de.hdodenhof.circleimageview.CircleImageView
                                            android:id="@+id/toolbarAvatar"
                                            android:layout_width="36dp"
                                            android:layout_height="36dp"
                                            android:layout_marginStart="8dp"
                                            android:src="@drawable/ic_user"
                                            android:visibility="invisible"
                                            app:civ_border_color="@color/surface"
                                            app:civ_border_width="1dp" />
            
                                        <!-- 折叠后显示的用户名 -->
                                        <TextView
                                            android:id="@+id/toolbarTitle"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="10dp"
                                            android:ellipsize="end"
                                            android:maxWidth="200dp"
                                            android:maxLines="1"
                                            android:textColor="@color/white"
                                            android:textSize="17sp"
                                            android:textStyle="bold"
                                            android:visibility="invisible"
                                            tools:text="用户名" />
            
                                    </LinearLayout>
            
                            </FrameLayout>
            
                        </androidx.appcompat.widget.Toolbar>
            
                    </com.google.android.material.appbar.CollapsingToolbarLayout>
            
                    <!-- TabLayout - 位于 CollapsingToolbarLayout 下方，滑动时固定在 Toolbar 下方 -->
                    <com.google.android.material.tabs.TabLayout
                        android:id="@+id/tabLayout"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@color/surface"
                        android:elevation="4dp"
                        app:tabIndicatorColor="@color/highlight_orange"
                        app:tabIndicatorFullWidth="false"
                        app:tabIndicatorHeight="3dp"
                        app:tabMode="fixed"
                        app:tabRippleColor="@android:color/transparent"
                        app:tabSelectedTextColor="@color/text_primary"
                        app:tabTextAppearance="@style/TabTextStyle"
                        app:tabTextColor="@color/text_secondary">
            
                        <com.google.android.material.tabs.TabItem
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="资料" />
            
                        <com.google.android.material.tabs.TabItem
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="帖子" />
            
                        <com.google.android.material.tabs.TabItem
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="回复" />
            
                    </com.google.android.material.tabs.TabLayout>
            
                </com.google.android.material.appbar.AppBarLayout>
    <!-- Tab内容区域 -->
    <FrameLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- 资料页面 -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/profileScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:background="@color/background">

            <LinearLayout
                android:id="@+id/profileContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <!-- 用户身份和积分资产合并卡片 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="20dp"
                        android:gravity="center">

                        <!-- UID -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/textUid"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="18sp"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="UID"
                                android:textSize="13sp"
                                android:textColor="@color/stats_label" />
                        </LinearLayout>

                        <!-- 分隔线 -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="@color/divider" />

                        <!-- 用户组 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/textUserGroup"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textSize="18sp"
                                android:textColor="@color/text_primary"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="用户组"
                                android:textSize="13sp"
                                android:textColor="@color/stats_label" />
                        </LinearLayout>

                        <!-- 分隔线 -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="@color/divider" />

                        <!-- 金币 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/goldCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="18sp"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="金币"
                                android:textSize="13sp"
                                android:textColor="@color/stats_label" />
                        </LinearLayout>

                        <!-- 分隔线 -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="@color/divider" />

                        <!-- 人气 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/popularityCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="18sp"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="人气"
                                android:textSize="13sp"
                                android:textColor="@color/stats_label" />
                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- 信誉好评卡片 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="20dp"
                        android:gravity="center">

                        <!-- 信誉 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/reputationCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="18sp"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="信誉"
                                android:textSize="13sp"
                                android:textColor="@color/stats_label" />
                        </LinearLayout>

                        <!-- 分隔线 -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="@color/divider" />

                        <!-- 好评 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/goodRateCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="18sp"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="好评"
                                android:textSize="13sp"
                                android:textColor="@color/stats_label" />
                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- 活动记录卡片 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="20dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="8dp">

                        <!-- 卡片标题 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="活动记录"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <!-- 信息列表 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical">

                            <!-- 注册时间 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="58dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="注册时间"
                                    android:textColor="@color/text_primary"
                                    android:textSize="16sp" />

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="0dp"
                                    android:layout_weight="1" />

                                <TextView
                                    android:id="@+id/regDate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="14sp"
                                    tools:text="2018-3-15" />

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_marginStart="8dp"
                                    android:src="@drawable/ic_arrow_right"
                                    android:tint="@color/icon_gray"
                                    android:alpha="0.5" />

                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/divider" />

                            <!-- 最后访问 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="58dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="最后访问"
                                    android:textColor="@color/text_primary"
                                    android:textSize="16sp" />

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="0dp"
                                    android:layout_weight="1" />

                                <TextView
                                    android:id="@+id/lastVisit"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="14sp"
                                    tools:text="2026-2-23" />

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_marginStart="8dp"
                                    android:src="@drawable/ic_arrow_right"
                                    android:tint="@color/icon_gray"
                                    android:alpha="0.5" />

                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/divider" />

                            <!-- 在线时间 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="58dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="在线时间"
                                    android:textColor="@color/text_primary"
                                    android:textSize="16sp" />

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="0dp"
                                    android:layout_weight="1" />

                                <TextView
                                    android:id="@+id/onlineTime"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="14sp"
                                    tools:text="170 小时" />

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_marginStart="8dp"
                                    android:src="@drawable/ic_arrow_right"
                                    android:tint="@color/icon_gray"
                                    android:alpha="0.5" />

                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/divider" />

                            <!-- 好友数 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="58dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="好友数"
                                    android:textColor="@color/text_primary"
                                    android:textSize="16sp" />

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="0dp"
                                    android:layout_weight="1" />

                                <TextView
                                    android:id="@+id/friendsCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="14sp"
                                    tools:text="0" />

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_marginStart="8dp"
                                    android:src="@drawable/ic_arrow_right"
                                    android:tint="@color/icon_gray"
                                    android:alpha="0.5" />

                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/divider" />

                            <!-- 回复数 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="58dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="回复数"
                                    android:textColor="@color/text_primary"
                                    android:textSize="16sp" />

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="0dp"
                                    android:layout_weight="1" />

                                <TextView
                                    android:id="@+id/replyCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="14sp"
                                    tools:text="282" />

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_marginStart="8dp"
                                    android:src="@drawable/ic_arrow_right"
                                    android:tint="@color/icon_gray"
                                    android:alpha="0.5" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- 帖子列表页面 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/threadRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            tools:listitem="@layout/item_post" />

        <!-- 回复列表页面 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/replyRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            tools:listitem="@layout/item_post" />

        <!-- 收藏列表页面 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/favoriteRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            tools:listitem="@layout/item_favorite" />

        <!-- 加载状态 -->
        <ProgressBar
            android:id="@+id/tabProgressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- 空状态提示 -->
        <LinearLayout
            android:id="@+id/emptyView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_empty"
                android:alpha="0.5" />

            <TextView
                android:id="@+id/emptyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="暂无内容"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

        </LinearLayout>

    </FrameLayout>

    <!-- 加载进度条 -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
