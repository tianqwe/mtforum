<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="24dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="踢帖"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/kickCloseButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:src="@drawable/ic_close"
            android:tint="@color/icon_normal" />

    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- 当前踢帖人数 -->
    <TextView
        android:id="@+id/kickCountText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:textColor="@color/highlight_orange"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- 踢帖人列表 -->
    <LinearLayout
        android:id="@+id/kickUsersContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="踢帖人："
            android:textColor="@color/text_light_gray"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/kickUsersAvatars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />

        <TextView
            android:id="@+id/kickUsersMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textColor="@color/text_light_gray"
            android:textSize="12sp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- 说明文字 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:text="可对以下情况使用踢帖功能："
        android:textColor="@color/info_blue"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:lineSpacingExtra="4dp"
        android:text="1. 存在广告/引流/色情的内容\n2. 涉及政治及宗教敏感的内容\n3. 价值过低却设置收费的内容\n4. 扰乱论坛秩序，辱骂，引战\n5. 其它违规且需要立即屏蔽的内容"
        android:textColor="@color/text_light_gray"
        android:textSize="12sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:lineSpacingExtra="4dp"
        android:text="踢帖人数达到 5 人后，帖子将立刻被隐藏。"
        android:textColor="@color/text_dark"
        android:textSize="12sp" />

    <!-- 理由输入框 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:text="踢帖理由："
        android:textColor="@color/text_dark"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:text="(实名踢帖，请认真填写，恶意者严肃处罚)"
        android:textColor="@color/danger_red"
        android:textSize="11sp" />

    <EditText
        android:id="@+id/kickReasonInput"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_input_field"
        android:gravity="start|top"
        android:hint="请输入踢帖理由（至少5个字符）"
        android:inputType="textMultiLine"
        android:maxLength="200"
        android:padding="12dp"
        android:textColor="@color/text_dark"
        android:textColorHint="@color/text_disabled"
        android:textSize="14sp" />

    <!-- 提交按钮 -->
    <TextView
        android:id="@+id/kickSubmitButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_button_danger"
        android:gravity="center"
        android:text="确定踢帖"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>