<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/paid_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 标题行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_coin_gold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="付费内容"
                android:textColor="@color/paid_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- 购买人数 -->
            <TextView
                android:id="@+id/paidBuyersText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/warning_orange"
                android:textSize="12sp"
                tools:text="已有 33 人购买" />

        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="@color/paid_divider" />

        <!-- 价格和截止日期 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/paidPriceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/paid_text"
                android:textSize="13sp"
                tools:text="需支付 2 金币" />

            <TextView
                android:id="@+id/paidDeadlineText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:textColor="@color/paid_deadline"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="截止: 2026-3-11 15:55"
                tools:visibility="visible" />

        </LinearLayout>

        <!-- 购买按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buyPostButton"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:text="立即购买"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            app:backgroundTint="@color/paid_button"
            app:cornerRadius="6dp" />

        <!-- 已购买提示 -->
        <TextView
            android:id="@+id/purchasedText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="您已购买此内容"
            android:textColor="@color/paid_purchased"
            android:textSize="13sp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.cardview.widget.CardView>