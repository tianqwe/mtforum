<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/code_bg"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 代码块标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="@color/code_header_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <!-- 代码语言标签 -->
            <TextView
                android:id="@+id/tvCodeLanguage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Code"
                android:textColor="@color/code_language"
                android:textSize="12sp" />

            <!-- 复制按钮 -->
            <TextView
                android:id="@+id/tvCopyCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="复制"
                android:textColor="@color/code_copy_link"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- 代码内容区域 -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp">

                <!-- 行号 -->
                <TextView
                    android:id="@+id/tvLineNumbers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="4dp"
                    android:text="1\n2\n3"
                    android:textColor="@color/code_line_number"
                    android:textSize="12sp" />

                <!-- 分隔线 -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="12dp"
                    android:background="@color/code_divider" />

                <!-- 代码内容 -->
                <TextView
                    android:id="@+id/tvCodeContent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="4dp"
                    android:text="code here"
                    android:textColor="@color/code_text"
                    android:textIsSelectable="true"
                    android:textSize="12sp" />

            </LinearLayout>

        </HorizontalScrollView>

        <!-- 代码行数统计 -->
        <TextView
            android:id="@+id/tvLineCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/code_header_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="共 0 行"
            android:textColor="@color/code_line_number"
            android:textSize="11sp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.cardview.widget.CardView>