<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/bg_bounty_item"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <!-- 悬赏金币信息行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/bountyIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_coin_gold" />

        <TextView
            android:id="@+id/bountyAmountText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="悬赏 5 金币"
            android:textColor="@color/bounty_amount"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/bountyAnswerBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bounty_action"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="我来回答"
            android:textColor="@color/bounty_button_text"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- 悬赏问题描述（可选） -->
    <TextView
        android:id="@+id/bountyContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_gray"
        android:textSize="13sp"
        android:visibility="gone" />

</LinearLayout>