<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_panel_card"
    android:padding="16dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:layout_width="3dp"
            android:layout_height="16dp"
            android:background="@color/huluxia_orange" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="权限设置"
            android:textColor="@color/text_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 帖子售价 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="帖子售价"
            android:textColor="@color/text_dark"
            android:textSize="14sp"
            android:minWidth="70dp" />

        <EditText
            android:id="@+id/priceInput"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_input_field"
            android:hint="0"
            android:inputType="number"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_disabled"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="金币"
            android:textColor="@color/text_gray"
            android:textSize="14sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/priceHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginStart="82dp"
        android:text="最高售价: 2 金币"
        android:textColor="@color/text_disabled"
        android:textSize="11sp" />

    <!-- 帖子密码 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="帖子密码"
            android:textColor="@color/text_dark"
            android:textSize="14sp"
            android:minWidth="70dp" />

        <EditText
            android:id="@+id/passwordInput"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_input_field"
            android:hint="请输入密码"
            android:inputType="textPassword"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_disabled"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/setPasswordButton"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_publish_button"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="确定"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginStart="82dp"
        android:text="密码将插入到内容最后"
        android:textColor="@color/text_disabled"
        android:textSize="11sp" />

</LinearLayout>