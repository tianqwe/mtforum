<?xml version="1.0" encoding="utf-8"?>
<!-- 版块信息头部布局 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface">
    
    <!-- 版块信息卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="?android:attr/selectableItemBackground">
        
        <!-- 版块图标 -->
        <androidx.cardview.widget.CardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F0F5FF">
            
            <ImageView
                android:id="@+id/forumIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:padding="8dp"
                android:src="@drawable/ic_forum"
                android:transitionName="forum_icon_transition"
                tools:ignore="ContentDescription" />
                
        </androidx.cardview.widget.CardView>

        <!-- 版块信息 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">
            
            <!-- 版块名称 -->
            <TextView
                android:id="@+id/forumName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="逆向交流"
                android:textColor="#1A1A2E"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

            <!-- 统计信息 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">
                
                <TextView
                    android:id="@+id/todayPosts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="今日 33"
                    android:textColor="#3B82F6"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                    
                <View
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginHorizontal="8dp"
                    android:background="#D1D5DB" />
                    
                <TextView
                    android:id="@+id/totalPosts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="帖子 208万"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
                    
                <View
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginHorizontal="8dp"
                    android:background="#D1D5DB" />
                    
                <TextView
                    android:id="@+id/followers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="关注 5257"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
                    
            </LinearLayout>
            
            <!-- 版块描述 -->
            <TextView
                android:id="@+id/forumDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="逆向技术交流分享，求助帖请发到其它板块~"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- 关注按钮 -->
        <FrameLayout
            android:id="@+id/btnFollow"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/bg_follow_btn_outlined"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="16dp">
            
            <TextView
                android:id="@+id/followText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="+ 关注"
                android:textColor="#3B82F6"
                android:textSize="13sp"
                android:textStyle="bold" />
                
        </FrameLayout>

    </LinearLayout>
    
    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:background="@color/placeholder" />

</LinearLayout>
